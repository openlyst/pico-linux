# Pico Neo 2 — Reduced kernel config for ABL boot
# Start from sdm845.config and disable modules/unnecessary features
# This keeps essential Qualcomm drivers while reducing size under 37MB

# Disable modules to reduce size
CONFIG_MODULES=n
CONFIG_MODULE_SIG=n

# Disable networking (not needed for initial boot)
CONFIG_NET=n
CONFIG_INET=n

# Disable wireless
CONFIG_WIRELESS=n
CONFIG_BT=n

# Disable sound
CONFIG_SOUND=n
CONFIG_SND=n

# Disable media support
CONFIG_MEDIA_SUPPORT=n
CONFIG_MEDIA_CAMERA_SUPPORT=n

# Disable input subsystem (keyboard/mouse)
CONFIG_INPUT=n

# Disable DRM/display (not needed for console boot)
CONFIG_DRM=n
CONFIG_FB=n
CONFIG_FRAMEBUFFER_CONSOLE=n

# Disable PCI
CONFIG_PCI=n

# Disable NFS
CONFIG_NFS_FS=n

# Disable extra filesystems
CONFIG_BTRFS_FS=n
CONFIG_XFS_FS=n
CONFIG_F2FS_FS=n

# Disable security frameworks
CONFIG_SECURITY=n
CONFIG_SECURITY_SELINUX=n
CONFIG_SECURITY_SMACK=n
CONFIG_SECURITY_TOMOYO=n
CONFIG_SECURITY_APPARMOR=n
CONFIG_SECURITY_YAMA=n

# Disable audit
CONFIG_AUDIT=n

# Disable crypto hardware acceleration
CONFIG_CRYPTO_DEV_QCE=n
CONFIG_CRYPTO_DEV_QCOM_RNG=n

# Disable EFI — ABL expects old-style ARM64 Image
CONFIG_EFI=n
CONFIG_EFI_STUB=n
CONFIG_EFI_PARTITION=y
